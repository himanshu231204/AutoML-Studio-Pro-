# EditorConfig for AutoML Studio Pro
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 100

[Makefile]
indent_style = tab

[Dockerfile]
indent_size = 4

[*.sh]
indent_size = 4

[*.bat]
indent_size = 4

[.github/**]
indent_size = 2

[*.{js,ts,jsx,tsx}]
indent_size = 2

[*.{css,scss,less}]
indent_size = 2

[*.html]
indent_size = 2
